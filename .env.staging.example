# ==========================================================================
# infra-sub — STAGING environment template
# --------------------------------------------------------------------------
# Set these on the Netlify *staging* deploy context (branch-scoped env vars),
# NOT in a committed file. This template documents the staging-vs-production
# differences. NEVER commit real secrets.
#
# Golden rule: staging is ISOLATED from production.
#   - Separate MongoDB Atlas cluster (its own data, its own least-priv user).
#   - PayHere SANDBOX only — no real money.
#   - Different JWT/CSRF secrets than production.
# ==========================================================================

# --- App ---
NEXT_PUBLIC_APP_URL="https://stage.sadishadilmin.com"
NODE_ENV="production"   # staging runs a production build

# --- Database (SEPARATE staging Atlas cluster) ---
# MUST NOT be the production cluster. Same region as prod for parity.
MONGODB_URI="mongodb+srv://STAGING_USER:STAGING_PASSWORD@staging-cluster.mongodb.net/infra_sub?retryWrites=true&w=majority"
MONGODB_DB_NAME="infra_sub"

# --- Auth / JWT (DIFFERENT values from production) ---
# openssl rand -base64 48
JWT_ACCESS_SECRET="staging-strong-random-secret-min-32-chars"
JWT_REFRESH_SECRET="staging-different-strong-random-secret"
JWT_ACCESS_TTL="900"
JWT_REFRESH_TTL="604800"
JWT_ISSUER="infra-sub"
JWT_AUDIENCE="infra-sub-clients"

# openssl rand -base64 32
CSRF_SECRET="staging-strong-random-secret"

# --- Email (SMTP via Spacemail) — use a staging sender ---
# Spacemail: host mail.spacemail.com, port 465 (SSL) or 587 (STARTTLS).
SMTP_HOST="mail.spacemail.com"
SMTP_PORT="465"
SMTP_SECURE="true"               # true for 465 (SSL); set false + port 587 for STARTTLS
SMTP_USER="no-reply@sadishadilmin.com"   # full Spacemail mailbox address
SMTP_PASSWORD="spacemail-mailbox-password"
EMAIL_FROM="Infra Sub (staging) <no-reply@sadishadilmin.com>"

# --- PayHere (SANDBOX ONLY on staging) ---
PAYHERE_MERCHANT_ID="1XXXXXX"                       # sandbox merchant id
PAYHERE_MERCHANT_SECRET="sandbox-merchant-secret"
PAYHERE_CHECKOUT_URL="https://sandbox.payhere.lk/pay/checkout"
PAYHERE_MODE="sandbox"
PAYHERE_CURRENCY="LKR"
PAYHERE_NOTIFY_URL="https://stage.sadishadilmin.com/api/webhooks/payhere"
PAYHERE_RETURN_URL="https://stage.sadishadilmin.com/dashboard/billing?status=success"
PAYHERE_CANCEL_URL="https://stage.sadishadilmin.com/dashboard/billing?status=cancelled"
PAYHERE_APP_ID=""
PAYHERE_APP_SECRET=""
PAYHERE_API_BASE="https://www.payhere.lk/merchant/v1"

# --- Bootstrap super admin (used by `npm run seed` against the STAGING DB) ---
SEED_ADMIN_EMAIL="admin@staging.yourdomain.com"
SEED_ADMIN_PASSWORD="ChangeMe_Strong_Password123!"
SEED_ADMIN_FIRST_NAME="Super"
SEED_ADMIN_LAST_NAME="Admin"

# --- Rate limiting (Upstash Redis REST) ---
# A SEPARATE Upstash database from production so counters don't collide.
RATE_LIMIT_REDIS_URL="https://<staging-db>.upstash.io"
RATE_LIMIT_REDIS_TOKEN="<staging-upstash-rest-token>"
