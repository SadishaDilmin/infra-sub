# ==========================================================================
# infra-sub — Environment Variables
# --------------------------------------------------------------------------
# Copy to `.env.local` for local dev. NEVER commit real secrets.
# On Vercel, set these in Project Settings → Environment Variables (or via
# `vercel env add`). See DEPLOYMENT.md for guidance and the COMPLIANCE notes
# regarding data residency (UK GDPR / EU).
# ==========================================================================

# --- App ---
# Public base URL of the app. Used for building links (email, PayHere returns).
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"

# --- Database (MongoDB Atlas) ---
# COMPLIANCE: choose an Atlas region consistent with your data-residency
# obligations. If you serve UK/EU data subjects, host in the UK/EU and document
# it in your ROPA. Do NOT default to a US region without a documented basis.
MONGODB_URI="mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/infra_sub?retryWrites=true&w=majority"
MONGODB_DB_NAME="infra_sub"

# --- Auth / JWT ---
# Generate strong random values, e.g.:  openssl rand -base64 48
# Access + refresh tokens use SEPARATE secrets so a leak of one cannot mint the other.
JWT_ACCESS_SECRET="replace-with-strong-random-secret-min-32-chars"
JWT_REFRESH_SECRET="replace-with-a-different-strong-random-secret"
JWT_ACCESS_TTL="900"            # access token lifetime, seconds (15m)
JWT_REFRESH_TTL="604800"        # refresh token lifetime, seconds (7d)
JWT_ISSUER="infra-sub"
JWT_AUDIENCE="infra-sub-clients"

# CSRF signing secret (double-submit token). openssl rand -base64 32
CSRF_SECRET="replace-with-strong-random-secret"

# --- Email (SMTP, used for verification + password reset) ---
# Example uses Spacemail (Spaceship): host mail.spacemail.com, port 465 (SSL)
# or 587 (STARTTLS). USER is the full mailbox address; PASSWORD is its password.
SMTP_HOST="mail.spacemail.com"
SMTP_PORT="465"
SMTP_SECURE="true"              # true for 465 (SSL); false + port 587 for STARTTLS
SMTP_USER="no-reply@yourdomain.com"
SMTP_PASSWORD="spacemail-mailbox-password"
EMAIL_FROM="Infra Sub <no-reply@yourdomain.com>"

# --- PayHere (https://www.payhere.lk) ---
# Merchant ID from the PayHere dashboard.
PAYHERE_MERCHANT_ID="1XXXXXX"
# Merchant Secret — used to compute/verify MD5 signatures. SERVER-ONLY secret.
PAYHERE_MERCHANT_SECRET="replace-with-payhere-merchant-secret"
# Use the sandbox endpoint for testing, the live endpoint in production.
# sandbox: https://sandbox.payhere.lk/pay/checkout
# live:    https://www.payhere.lk/pay/checkout
PAYHERE_CHECKOUT_URL="https://sandbox.payhere.lk/pay/checkout"
PAYHERE_MODE="sandbox"          # "sandbox" | "live"
PAYHERE_CURRENCY="LKR"          # PayHere supports LKR and USD
# App-side notify/return URLs (must be publicly reachable for webhooks).
PAYHERE_NOTIFY_URL="http://localhost:3000/api/webhooks/payhere"
PAYHERE_RETURN_URL="http://localhost:3000/dashboard/billing?status=success"
PAYHERE_CANCEL_URL="http://localhost:3000/dashboard/billing?status=cancelled"
# Optional — PayHere "Business App" credentials (Dashboard → Integrations → Create App).
# Required ONLY to cancel recurring subscriptions via the Subscription Manager API.
PAYHERE_APP_ID=""
PAYHERE_APP_SECRET=""
PAYHERE_API_BASE="https://www.payhere.lk/merchant/v1"

# --- Bootstrap super admin (used by `npm run seed`) ---
SEED_ADMIN_EMAIL="admin@yourdomain.com"
SEED_ADMIN_PASSWORD="ChangeMe_Strong_Password123!"
SEED_ADMIN_FIRST_NAME="Super"
SEED_ADMIN_LAST_NAME="Admin"

# --- Rate limiting (Upstash Redis REST) ---
# In-memory by default (fine for a single instance / local dev). For
# multi-instance / serverless production (Netlify) you MUST set BOTH of these to
# an Upstash Redis database's REST URL + token, or rate limiting won't actually
# bound traffic across isolates. See SECURITY.md / NETLIFY-DEPLOYMENT.md.
RATE_LIMIT_REDIS_URL=""           # e.g. https://xxxx.upstash.io
RATE_LIMIT_REDIS_TOKEN=""         # Upstash REST token
